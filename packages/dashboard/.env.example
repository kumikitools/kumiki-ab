# Kumiki A/B dashboard — single-tenant, server-side config.
# Copy to .env.local and fill in. These are read ONLY on the server; the write
# key never reaches the browser.

# Origin of your self-hosted control API (the Worker). No trailing slash needed.
KUMIKI_API_URL=https://kumiki.your-account.workers.dev

# The site's write key (the bearer token the control routes authenticate).
KUMIKI_API_KEY=wk_your_write_key

# The single site this dashboard manages.
KUMIKI_SITE_ID=site_xxxxxxxx
